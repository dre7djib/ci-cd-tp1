{
  "name": "node-api",
  "version": "1.0.9",
  "description": "Minimal Node.js API using Express",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc",
    "start": "npm run build && node index.js",
    "lint": "node ./node_modules/eslint/bin/eslint.js index.js",
    "ts": "node ./node_modules/typescript/bin/tsc --noEmit",
    "test": "node ./node_modules/jest/bin/jest.js",
    "load-test": "k6 run load-test.js",
    "seed": "npm run build && node dist/scripts/seed.js",
    "prepare": "node -e \"try{require('husky').install()}catch(e){process.exit(0)}\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.2",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.0.0",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "napi-postinstall": "^0.3.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.6.3"
  }
}
