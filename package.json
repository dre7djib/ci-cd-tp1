{
  "name": "node-api",
  "version": "1.0.0",
  "description": "Minimal Node.js API using Express",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "lint": "node ./node_modules/eslint/bin/eslint.js index.js",
    "ts": "node ./node_modules/typescript/bin/tsc --noEmit",
    "test": "jest",
    "prepare": "node -e \"try{require('husky').install()}catch(e){process.exit(0)}\""
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "eslint": "^10.0.0",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "napi-postinstall": "^0.3.4",
    "typescript": "^5.6.3"
  }
}
